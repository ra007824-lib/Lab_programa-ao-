pares = []
impares = []

while len(pares) + len(impares) < 10:
    num = int(input("Digite um número inteiro: "))

    if num in pares or num in impares:
        print("Número já inserido! Digite outro.")
        continue

    if num % 2 == 0:
        pares.append(num)
    else:
        impares.append(num)

print("\nLista de pares:", pares)
print("Lista de ímpares:", impares)


